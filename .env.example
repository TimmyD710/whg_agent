# Gemini CLI command (optional)
GEMINI_CMD=gemini

# Mail configuration (required for email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=timmydueren@gmail.com

# Optional: set to true to keep emails local during testing
DRY_RUN=false
